{
  "uid": "v12-2-adhoc",
  "title": "Grafana 12.2 \u2014 Ad-hoc Filters (enhanced)",
  "description": "The ad-hoc filter UX was rebuilt and went GA in 12.2 (`adhocFiltersNew`). Pick any label at the top of the dashboard and every panel below filters to it.",
  "tags": [
    "grafana-12",
    "v12.2",
    "adhoc",
    "variables",
    "v12-demo"
  ],
  "schemaVersion": 40,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "ds_prom",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "current": {
          "text": "Prometheus",
          "value": "prom"
        }
      },
      {
        "name": "filter",
        "type": "adhoc",
        "datasource": {
          "uid": "${ds_prom}",
          "type": "prometheus"
        },
        "hide": 0,
        "label": "Ad-hoc filter"
      }
    ]
  },
  "panels": [
    {
      "id": 10000,
      "type": "text",
      "title": "",
      "tags": [
        "demo-guide"
      ],
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "html",
        "content": "<div style=\"padding:1.2rem;background:#1a2a3a;border-left:4px solid #5794f2;border-radius:6px;font-family:system-ui\"><div style=\"font-size:.75rem;letter-spacing:.18em;color:#8aa9d0;margin-bottom:.3rem\">DEMO GUIDE</div><div style=\"font-size:1.3rem;font-weight:600;color:#fff;margin-bottom:.6rem\">Grafana 12.2 \u2014 Ad-hoc Filters (enhanced)</div><div style=\"display:grid;grid-template-columns:1fr 1fr;gap:1rem\"><div><div style=\"font-weight:600;color:#5794f2;margin-bottom:.2rem\">\ud83c\udfaf What you're looking at</div><div style=\"font-size:.88rem;color:#dfe7f0\">v12.2 made the ad-hoc filter UX a first-class control. Pick any label + value at the top of the dashboard and every panel filters automatically.</div></div><div><div style=\"font-weight:600;color:#73bf69;margin-bottom:.2rem\">\ud83e\uddea Try this</div><div style=\"font-size:.88rem;color:#dfe7f0\">Use the 'Ad-hoc filter' control above the panels \u2014 pick `job=grafana` or `name=grafana12_loki`.</div></div></div><div style=\"margin-top:.8rem;padding-top:.6rem;border-top:1px solid #2d3e54;font-size:.85rem\">\ud83d\udcda <strong style=\"color:#fff\">Learn more</strong>: <a href=\"https://grafana.com/docs/grafana/latest/dashboards/variables/add-template-variables/#add-an-ad-hoc-filters-variable\" target=\"_blank\" style=\"color:#ff9830\">Grafana docs</a> \u00b7 <a href=\"https://grafana.com/docs/grafana/latest/whatsnew/whats-new-in-v12-2/\" target=\"_blank\" style=\"color:#ff9830\">v12 What's New</a></div></div>"
      }
    },
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "options": {
        "mode": "markdown",
        "content": "Pick a label + value in the **Ad-hoc filter** at the top. Both panels re-query automatically \u2014 no expression editing needed. Try `job=grafana` or `name=grafana12_loki`."
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "up{\u2026adhoc filters\u2026}",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "uid": "${ds_prom}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up",
          "legendFormat": "{{job}} / {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last"
          ]
        }
      },
      "description": "up{\u2026adhoc filters\u2026}. Reference: https://grafana.com/docs/grafana/latest/dashboards/variables/add-template-variables/#add-an-ad-hoc-filters-variable"
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "container_memory_usage_bytes{\u2026adhoc filters\u2026}",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "datasource": {
        "uid": "${ds_prom}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "container_memory_usage_bytes{name!=\"\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "max",
            "last"
          ]
        }
      },
      "description": "container_memory_usage_bytes{\u2026adhoc filters\u2026}. Reference: https://grafana.com/docs/grafana/latest/dashboards/variables/add-template-variables/#add-an-ad-hoc-filters-variable"
    }
  ]
}