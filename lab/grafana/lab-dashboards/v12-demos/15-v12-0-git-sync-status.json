            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "gitSync feature toggle. Reference: https://grafana.com/docs/grafana/latest/administration/provisioning/"
    },
