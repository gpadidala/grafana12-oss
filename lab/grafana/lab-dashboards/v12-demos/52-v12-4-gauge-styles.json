{
  "uid": "v12-4-gauge",
  "title": "Grafana 12.4 \u2014 Gauge Styles (Circular + Arc)",
  "description": "12.4 redesigned the gauge panel and added a `Style` option with Circular and Arc variants. Both layouts below query live container and DB metrics.",
  "tags": [
    "grafana-12",
    "v12.4",
    "gauge",
    "v12-demo"
  ],
  "schemaVersion": 40,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "ds_prom",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "current": {
          "text": "Prometheus",
          "value": "prom"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 10000,
      "type": "text",
      "title": "",
      "tags": [
        "demo-guide"
      ],
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "html",
        "content": "<div style=\"padding:1.2rem;background:#1a2a3a;border-left:4px solid #5794f2;border-radius:6px;font-family:system-ui\"><div style=\"font-size:.75rem;letter-spacing:.18em;color:#8aa9d0;margin-bottom:.3rem\">DEMO GUIDE</div><div style=\"font-size:1.3rem;font-weight:600;color:#fff;margin-bottom:.6rem\">Grafana 12.4 \u2014 Gauge Styles (Circular + Arc)</div><div style=\"display:grid;grid-template-columns:1fr 1fr;gap:1rem\"><div><div style=\"font-weight:600;color:#5794f2;margin-bottom:.2rem\">\ud83c\udfaf What you're looking at</div><div style=\"font-size:.88rem;color:#dfe7f0\">v12.4 redesigned the gauge with a Style option \u2014 Circular or Arc.</div></div><div><div style=\"font-weight:600;color:#73bf69;margin-bottom:.2rem\">\ud83e\uddea Try this</div><div style=\"font-size:.88rem;color:#dfe7f0\">Edit any gauge \u2192 Panel options \u2192 Style. Switch between Circular and Arc.</div></div></div><div style=\"margin-top:.8rem;padding-top:.6rem;border-top:1px solid #2d3e54;font-size:.85rem\">\ud83d\udcda <strong style=\"color:#fff\">Learn more</strong>: <a href=\"https://grafana.com/docs/grafana/latest/panels-visualizations/visualizations/gauge/\" target=\"_blank\" style=\"color:#ff9830\">Grafana docs</a> \u00b7 <a href=\"https://grafana.com/docs/grafana/latest/whatsnew/whats-new-in-v12-4/\" target=\"_blank\" style=\"color:#ff9830\">v12 What's New</a></div></div>"
      }
    },
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "options": {
        "mode": "markdown",
        "content": "Two gauge rows \u2014 first uses **Circular** (the 12.4 default), second uses **Arc**. Edit any panel to see the new `Style` dropdown under *Panel options*."
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Grafana container memory \u2014 Circular",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "uid": "${ds_prom}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "container_memory_usage_bytes{name=\"grafana12_grafana\"} / 1024 / 1024"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": {},
        "sizing": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "MB",
          "min": 0,
          "max": 512,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 256
              },
              {
                "color": "red",
                "value": 400
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "Grafana container memory \u2014 Circular. Reference: https://grafana.com/docs/grafana/latest/panels-visualizations/visualizations/gauge/"
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Postgres connections \u2014 Circular",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "datasource": {
        "uid": "${ds_prom}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_stat_activity_count{state=\"active\"} or on() vector(0)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "Postgres connections \u2014 Circular. Reference: https://grafana.com/docs/grafana/latest/panels-visualizations/visualizations/gauge/"
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Loki ingestion \u2014 Circular",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "datasource": {
        "uid": "${ds_prom}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(loki_distributor_bytes_received_total[1m])) or on() vector(0)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "Loki ingestion \u2014 Circular. Reference: https://grafana.com/docs/grafana/latest/panels-visualizations/visualizations/gauge/"
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "HTTP p95 (Arc style)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "uid": "${ds_prom}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le)(rate(grafana_http_request_duration_seconds_bucket[5m])))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 1,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.2
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "HTTP p95 (Arc style). Reference: https://grafana.com/docs/grafana/latest/panels-visualizations/visualizations/gauge/"
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "HTTP p50 (Arc style)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 18
      },
      "datasource": {
        "uid": "${ds_prom}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le)(rate(grafana_http_request_duration_seconds_bucket[5m])))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 0.5,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.3
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "HTTP p50 (Arc style). Reference: https://grafana.com/docs/grafana/latest/panels-visualizations/visualizations/gauge/"
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Goroutines (Arc)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 18
      },
      "datasource": {
        "uid": "${ds_prom}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "go_goroutines{job=\"grafana\"}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 500,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 200
              },
              {
                "color": "red",
                "value": 400
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "Goroutines (Arc). Reference: https://grafana.com/docs/grafana/latest/panels-visualizations/visualizations/gauge/"
    }
  ]
}