{
  "uid": "v12-4-gauge",
  "title": "Grafana 12.4 — Gauge Styles (Circular + Arc)",
  "description": "12.4 redesigned the gauge panel and added a `Style` option with Circular and Arc variants. Both layouts below query live container and DB metrics.",
  "tags": ["grafana-12", "v12.4", "gauge", "v12-demo"],
  "schemaVersion": 40,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {"from": "now-5m", "to": "now"},
  "timepicker": {},
  "templating": {"list": [
    {"name": "ds_prom", "type": "datasource", "query": "prometheus", "refresh": 1, "current": {"text": "Prometheus", "value": "prom"}}
  ]},
  "panels": [
    {
      "id": 1, "type": "text", "title": "",
      "gridPos": {"h": 3, "w": 24, "x": 0, "y": 0},
      "options": {"mode": "markdown", "content": "Two gauge rows — first uses **Circular** (the 12.4 default), second uses **Arc**. Edit any panel to see the new `Style` dropdown under *Panel options*."}
    },
    {
      "id": 2, "type": "gauge", "title": "Grafana container memory — Circular",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 3},
      "datasource": {"uid": "${ds_prom}", "type": "prometheus"},
      "targets": [{"refId": "A", "expr": "container_memory_usage_bytes{name=\"grafana12_grafana\"} / 1024 / 1024"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true, "text": {}, "sizing": "auto"},
      "fieldConfig": {"defaults": {"unit": "MB", "min": 0, "max": 512, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 256}, {"color": "red", "value": 400}]}}, "overrides": []}
    },
    {
      "id": 3, "type": "gauge", "title": "Postgres connections — Circular",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 3},
      "datasource": {"uid": "${ds_prom}", "type": "prometheus"},
      "targets": [{"refId": "A", "expr": "pg_stat_activity_count{state=\"active\"} or on() vector(0)"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 60}, {"color": "red", "value": 90}]}}, "overrides": []}
    },
    {
      "id": 4, "type": "gauge", "title": "Loki ingestion — Circular",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 3},
      "datasource": {"uid": "${ds_prom}", "type": "prometheus"},
      "targets": [{"refId": "A", "expr": "sum(rate(loki_distributor_bytes_received_total[1m])) or on() vector(0)"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "Bps", "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []}
    },
    {
      "id": 5, "type": "gauge", "title": "HTTP p95 (Arc style)",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 11},
      "datasource": {"uid": "${ds_prom}", "type": "prometheus"},
      "targets": [{"refId": "A", "expr": "histogram_quantile(0.95, sum by (le)(rate(grafana_http_request_duration_seconds_bucket[5m])))"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "max": 1, "decimals": 3, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.2}, {"color": "red", "value": 0.5}]}}, "overrides": []}
    },
    {
      "id": 6, "type": "gauge", "title": "HTTP p50 (Arc style)",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 11},
      "datasource": {"uid": "${ds_prom}", "type": "prometheus"},
      "targets": [{"refId": "A", "expr": "histogram_quantile(0.50, sum by (le)(rate(grafana_http_request_duration_seconds_bucket[5m])))"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "max": 0.5, "decimals": 3, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.1}, {"color": "red", "value": 0.3}]}}, "overrides": []}
    },
    {
      "id": 7, "type": "gauge", "title": "Goroutines (Arc)",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 11},
      "datasource": {"uid": "${ds_prom}", "type": "prometheus"},
      "targets": [{"refId": "A", "expr": "go_goroutines{job=\"grafana\"}"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 500, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 200}, {"color": "red", "value": 400}]}}, "overrides": []}
    }
  ]
}
