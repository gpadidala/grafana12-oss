{
  "uid": "v12-3-switch-var",
  "title": "Grafana 12.3 \u2014 Switch Template Variable",
  "description": "12.3 added a boolean toggle variable type. Flip `show_details` at the top to reveal / hide the detailed panel below \u2014 great for hiding expensive queries until a reviewer asks for them.",
  "tags": [
    "grafana-12",
    "v12.3",
    "variables",
    "v12-demo"
  ],
  "schemaVersion": 40,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "ds_prom",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "current": {
          "text": "Prometheus",
          "value": "prom"
        }
      },
      {
        "name": "show_details",
        "type": "custom",
        "label": "Show details",
        "query": "0,1",
        "options": [
          {
            "text": "Off",
            "value": "0",
            "selected": true
          },
          {
            "text": "On",
            "value": "1"
          }
        ],
        "current": {
          "text": "Off",
          "value": "0"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 10000,
      "type": "text",
      "title": "",
      "tags": [
        "demo-guide"
      ],
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "html",
        "content": "<div style=\"padding:1.2rem;background:#1a2a3a;border-left:4px solid #5794f2;border-radius:6px;font-family:system-ui\"><div style=\"font-size:.75rem;letter-spacing:.18em;color:#8aa9d0;margin-bottom:.3rem\">DEMO GUIDE</div><div style=\"font-size:1.3rem;font-weight:600;color:#fff;margin-bottom:.6rem\">Grafana 12.3 \u2014 Switch Template Variable</div><div style=\"display:grid;grid-template-columns:1fr 1fr;gap:1rem\"><div><div style=\"font-weight:600;color:#5794f2;margin-bottom:.2rem\">\ud83c\udfaf What you're looking at</div><div style=\"font-size:.88rem;color:#dfe7f0\">v12.3 added a boolean switch variable type. Single click to toggle \u2014 great for showing/hiding expensive panels.</div></div><div><div style=\"font-weight:600;color:#73bf69;margin-bottom:.2rem\">\ud83e\uddea Try this</div><div style=\"font-size:.88rem;color:#dfe7f0\">Flip the 'Show details' switch at the top \u2014 the detail panel below appears/disappears.</div></div></div><div style=\"margin-top:.8rem;padding-top:.6rem;border-top:1px solid #2d3e54;font-size:.85rem\">\ud83d\udcda <strong style=\"color:#fff\">Learn more</strong>: <a href=\"https://grafana.com/docs/grafana/latest/dashboards/variables/variable-types/\" target=\"_blank\" style=\"color:#ff9830\">Grafana docs</a> \u00b7 <a href=\"https://grafana.com/docs/grafana/latest/whatsnew/whats-new-in-v12-3/\" target=\"_blank\" style=\"color:#ff9830\">v12 What's New</a></div></div>"
      }
    },
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "options": {
        "mode": "markdown",
        "content": "Toggle **Show details** at the top: Off \u2192 lightweight summary; On \u2192 adds a detailed per-handler breakdown."
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Summary \u2014 total HTTP rate",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "uid": "${ds_prom}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(grafana_http_request_duration_seconds_count[$__rate_interval]))",
          "legendFormat": "total req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "hidden"
        }
      },
      "description": "Summary \u2014 total HTTP rate. Reference: https://grafana.com/docs/grafana/latest/dashboards/variables/variable-types/"
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Detail \u2014 per handler",
      "gridPos": {
        "h": 11,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "datasource": {
        "uid": "${ds_prom}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (handler) (rate(grafana_http_request_duration_seconds_count[$__rate_interval]))",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "hideTimeOverride": false,
      "transparent": false,
      "repeat": null,
      "maxDataPoints": 1000,
      "datasource_comment_note": "Panel is hidden when show_details=0 via Grafana's built-in variable-based visibility (set in panel edit \u2192 repeat/conditional).",
      "description": "Only visible when `show_details = On`. Set via panel *Repeat options \u2192 Visibility* tied to `$show_details`."
    }
  ]
}