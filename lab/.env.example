# grafana12-oss local lab environment — exact-patch pins.
# Copy to .env and fill in. Never commit .env with real secrets.
#
# INSECURE LAB MODE is on by default so the stack works behind a corporate proxy
# with self-signed certs. DO NOT use these defaults in prod.

# --- Images (pinned; never :latest, never minor-only) ---
GRAFANA_IMAGE_TAG=12.4.3
GRAFANA_RENDERER_TAG=3.12.0
POSTGRES_TAG=16-alpine
PROMETHEUS_TAG=v2.55.0
LOKI_TAG=3.3.0
TEMPO_TAG=2.6.0
PYROSCOPE_TAG=1.8.0
ALLOY_TAG=v1.6.0

# --- Corporate proxy (leave blank if no proxy) ---
# Used both at `docker build` (build args) and at runtime (container env).
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,renderer,prometheus,loki,tempo,pyroscope,alloy,grafana,.svc,.local

# --- Grafana admin ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME
GF_SECURITY_SECRET_KEY=CHANGE_ME_32_BYTES_HEX   # openssl rand -hex 32

# --- Server (HTTP, no TLS at the edge; Traefik can front later) ---
GF_SERVER_PROTOCOL=http
GF_SERVER_ROOT_URL=http://localhost:3012
GF_SERVER_DOMAIN=localhost
GF_SERVER_ENFORCE_DOMAIN=false

# --- INSECURE LAB MODE — toggle block ---
# Anonymous Admin so you don't fight login while iterating.
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_NAME=Main Org.
GF_AUTH_ANONYMOUS_ORG_ROLE=Admin
GF_AUTH_ANONYMOUS_DEVICE_LIMIT=0
GF_AUTH_BASIC_ENABLED=true
GF_AUTH_DISABLE_LOGIN_FORM=false

# Land straight on the overview dashboard instead of the empty welcome page.
GF_USERS_HOME_PAGE=/d/v12-upgrade-overview/v12-upgrade-overview
GF_USERS_DEFAULT_THEME=dark

# Relax cookie/CSP/HSTS so http://localhost works behind corporate proxies.
GF_SECURITY_COOKIE_SECURE=false
GF_SECURITY_COOKIE_SAMESITE=lax
GF_SECURITY_STRICT_TRANSPORT_SECURITY=false
GF_SECURITY_CONTENT_SECURITY_POLICY=false
GF_SECURITY_ALLOW_EMBEDDING=true

# Allow any unsigned plugin (lab only) and skip plugin signature checks.
GF_PLUGINS_ALLOW_LOADING_UNSIGNED_PLUGINS=*
GF_PLUGINS_PUBLIC_KEY_RETRIEVAL_DISABLED=true
GF_PLUGINS_PREINSTALL_DISABLED=true

# Don't phone home through the corporate proxy.
GF_ANALYTICS_REPORTING_ENABLED=false
GF_ANALYTICS_CHECK_FOR_UPDATES=false
GF_ANALYTICS_CHECK_FOR_PLUGIN_UPDATES=false
GF_NEWS_NEWS_FEED_ENABLED=false

GF_USERS_ALLOW_SIGN_UP=false

# --- Grafana DB (Postgres — hard constraint, never SQLite) ---
GF_DATABASE_TYPE=postgres
GF_DATABASE_HOST=postgres:5432
GF_DATABASE_NAME=grafana
GF_DATABASE_USER=grafana
GF_DATABASE_PASSWORD=CHANGE_ME
POSTGRES_ROOT_PASSWORD=CHANGE_ME
GF_DATABASE_SSL_MODE=disable

# --- Image Renderer (separate service) ---
GF_RENDERING_SERVER_URL=http://renderer:8081/render
GF_RENDERING_CALLBACK_URL=http://grafana:3000/
RENDERER_AUTH_TOKEN=CHANGE_ME_RENDERER_TOKEN   # openssl rand -hex 32

# --- Logging ---
GF_LOG_MODE=console
GF_LOG_LEVEL=info
GF_LOG_FORMAT=json

# --- Feature toggles (docs/06-feature-toggle-reference.md source of truth) ---
GF_FEATURE_TOGGLES_ENABLE=provisioning,kubernetesDashboards,dashboardsNewLayouts,dashboardScene,grafanaManagedRecordingRules,sqlExpressions,regressionTransformation,adhocFiltersNew,logsPanelControls,panelTimeSettings,gitSync,templateVariablesRegexTransform,multiVariableProperties,suggestedDashboards,otlpLogs,metricsDrilldown,logsDrilldown,tracesDrilldown,profilesDrilldown

# --- Hard rules kept even in insecure mode ---
GF_PLUGINS_ANGULAR_SUPPORT_ENABLED=false
GF_DASHBOARDS_MIN_REFRESH_INTERVAL=5s
GF_UNIFIED_ALERTING_ENABLED=true

# --- Dataproxy: generous timeouts to survive slow office networks ---
GF_DATAPROXY_TLS_HANDSHAKE_TIMEOUT_SECONDS=30
GF_DATAPROXY_TIMEOUT=60
