{
  "uid": "grafana-self",
  "title": "Grafana Self-Monitoring (12.4)",
  "description": "Internal Grafana metrics. Drops legacy cache_size (removed in 13). Uses 12.4 HA Alertmanager cluster metric prefix.",
  "tags": ["v12-migration", "platform"],
  "schemaVersion": 40,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "templating": {"list": [
    {"name": "datasource", "type": "datasource", "query": "prometheus", "current": {"text": "Prometheus", "value": "prom"}},
    {"name": "pod", "type": "query", "datasource": {"uid": "${datasource}"}, "query": "label_values(grafana_build_info, pod)", "refresh": 2, "multi": true, "includeAll": true}
  ]},
  "panels": [
    {"id": 1, "type": "stat", "title": "Build info", "gridPos": {"h": 4, "w": 12, "x": 0, "y": 0},
     "datasource": {"uid": "${datasource}"}, "targets": [{"refId": "A", "expr": "grafana_build_info{pod=~\"$pod\"}"}]},
    {"id": 2, "type": "timeseries", "title": "HTTP request duration p95", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
     "datasource": {"uid": "${datasource}"},
     "targets": [{"refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(grafana_http_request_duration_seconds_bucket{pod=~\"$pod\"}[$__rate_interval])))"}]},
    {"id": 3, "type": "timeseries", "title": "HA Alertmanager peers (12.4 prefix)", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
     "datasource": {"uid": "${datasource}"},
     "targets": [{"refId": "A", "expr": "grafana_alerting_ha_members{pod=~\"$pod\"}"}]}
  ]
}
